{
  "name": "picto",
  "version": "0.1.0",
  "description": "Tiny React library for procedural SVG characters. Seed in, character out.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./rng": {
      "import": {
        "types": "./dist/rng.d.ts",
        "default": "./dist/rng.js"
      },
      "require": {
        "types": "./dist/rng.d.cts",
        "default": "./dist/rng.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "svg",
    "avatar",
    "procedural",
    "generative",
    "character",
    "picto"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
